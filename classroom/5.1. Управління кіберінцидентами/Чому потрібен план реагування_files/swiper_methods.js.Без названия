        }
    }
};

var authenticationPopup = new Swiper(authenticationPopupSelector, swiperOptions);
function show_popup(){
    authenticationPopup.update();
    document.querySelector('[data-login-popup]').classList.add('active');
}

document.addEventListener('click', function (event) {
    if(event.target.matches('#login-popup .authentication-popup-container .forgot-pas')){
        event.preventDefault();
        authenticationPopup.slideTo(1);
    }

    if(event.target.matches('#login-popup .authentication-popup-container .back-to-login')){
        event.preventDefault();
        authenticationPopup.slideTo(0);
    }

});
if (document.querySelector('#login-popup .authentication-popup-container .back-to-sign-up')) {
    document.querySelector('#login-popup .authentication-popup-container .back-to-sign-up').addEventListener('click', function (e) {
        authenticationPopup.slideTo(3);
        e.preventDefault();
    });
}



document.querySelectorAll('#login-popup .close-popup').forEach(function (el) {
    el.addEventListener('click', function (e) {
        document.querySelector('#login-popup').classList.remove('active');
    });
});

document.querySelectorAll('#end-subscription-popup .close-popup').forEach(function (el) {
