
function galleryTopInit() {
    var galleryTops = document.querySelectorAll('.gallery-top:not(.gallery-top--processed)');

    galleryTops.forEach(function (galleryTopEl) {
        galleryTopEl.classList.add('gallery-top--processed');

        var currentThumbs = galleryTopEl.closest('.media__gallery').querySelector('.gallery-thumbs'),
            currentCounter = galleryTopEl.closest('.media__gallery').querySelector('.photo-counter'),
            currentGalleryExpand = galleryTopEl.closest('.media__gallery').querySelector('[data-action="resize_gallery"]');

        var galleryThumbs = new Swiper(currentThumbs, {
            spaceBetween: 0,
            centeredSlides: false,
            // slidesPerView: 'auto',
            touchRatio: 0.2,
            slidesPerView: 7,
            slideToClickedSlide: true,
            nested: true,
            resistanceRatio: 0,
        });
        var galleryTop = new Swiper(galleryTopEl, {
            slidesPerView: 1,
            spaceBetween: 10,
            nested: true,
            resistanceRatio: 0,
            preloadImages: false,
            lazy: true,
            autoHeight: false,
            navigation: {
                nextEl: galleryTopEl.querySelector('.swiper-btn.button-next'),
                prevEl: galleryTopEl.querySelector('.swiper-btn.button-prev')
            },
            pagination: {
                el: currentCounter,
                type: 'custom',
                renderCustom: function (swiper, current, total) {
                    return '<span class="red-color">' + current + '</span>/<span>' + total + '</span>';
                }
            },
            on: {
                init: function () {
                    if (galleryTopEl.querySelector('.gallery-top .swiper-slide-active')) {
                        var slideCaption = galleryTopEl.querySelector('.gallery-top .swiper-slide-active').getAttribute("data-caption"),
                            slideSource = galleryTopEl.querySelector('.gallery-top .swiper-slide-active').getAttribute("data-source");
                        galleryTopEl.closest('.media__gallery').querySelector('.gallery_description').textContent = slideCaption;
                        galleryTopEl.closest('.media__gallery').querySelector('.gallery__footer_source').textContent = slideSource;
                    }
                },
                slideChange: function () {
                    var slideCaption = galleryTop.slides[galleryTop.activeIndex].getAttribute("data-caption"),
                        slideSource = galleryTop.slides[galleryTop.activeIndex].getAttribute("data-source");
                    galleryTopEl.closest('.media__gallery').querySelector('.gallery_description').textContent = slideCaption;
                    galleryTopEl.closest('.media__gallery').querySelector('.gallery__footer_source').textContent = slideSource;
                }
            }
        });
        /*var galleryTopSwiperBtn = {
            nextEl: galleryTopEl.querySelector('.swiper-btn.button-next'),
            prevEl: galleryTopEl.querySelector('.swiper-btn.button-prev')
        };

        var galleryTopSwiperPagination = {
            el: currentCounter,
            type: 'custom',
            renderCustom: function (swiper, current, total) {
                return '<span class="red-color">' + current + '</span>/<span>' + total + '</span>';
            }
        };*/



        galleryThumbs.controller.control = galleryTop;
        galleryTop.controller.control = galleryThumbs;

        currentGalleryExpand.addEventListener('click', function () {
            this.closest('.gallery__container').classList.toggle('full_screen');
            this.querySelector('span').classList.toggle('icon-scrabble');
            this.querySelector('span').classList.toggle('icon-expand');
            galleryTop.update();
            galleryThumbs.update();
        });
    });
}


