});


var form_login = document.querySelector(".login-form");
var form_register = document.querySelector(".register-form");
var swiperContainer_login;
var swiperContainer_register;
var swiper_register;
var togglePassword = document.querySelector('#toggle-password');
var password = document.querySelector('#password');

function updateSwiperContainer() {
    setTimeout(function () {
        if (swiper_login) {
            swiper_login.updateAutoHeight(600);
        }
    }, 100)
}

function updateSwiperContainer_register() {
    setTimeout(function () {
        if (swiper_register) {
            swiper_register.updateAutoHeight(600);
        }
    }, 100)
}

if (togglePassword) {
    togglePassword.addEventListener('click', function (e) {
        const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
        password.setAttribute('type', type);
        this.classList.toggle('icon-eye');
        this.classList.toggle('icon-eye-slash');
    });
}
form_login.addEventListener('submit', function (e) {
    e.preventDefault();

    form_login.classList.add('pending');

    swiperContainer_login = form_login.closest('.swiper-container');

    if (swiperContainer_login && swiperContainer_login) {
        swiper_login = swiperContainer_login.swiper;
    } else {
        swiper_login = false;
    }

    var formData = new FormData(form_login);
    window.dataLayer.push({
        'event': 'login',
        'eventLabel': 'form',
    });

    for (const [key, value] of formData) {
        console.log(`${key}: ${value}\n`);
    }

    fetch('/user_login', {
        method: 'POST',
        headers: {
            // 'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
        },
        body: formData
    }).then(response => response.json())
        .then(data => {
//            console.log(data);
            if (data.status === 'ok') {
                if (data.redirect !== '') {
                    window.location.href = data.redirect;
                } else {
                    window.location.reload();
                }
            } else if (data.message === "too_many_attempts") {
                form_login.querySelector('#error-login-many-attempts').style.display = 'block';
            } else if (data.message === "auth_failed" || data.message === "invalid_credential") {
                form_login.querySelector('#error-login-auth').style.display = 'block';
            } else {
                form_login.querySelector('#error-login-oops').style.display = 'block';
            }

            form_login.classList.remove('pending');

            if (swiperContainer_login) {
                updateSwiperContainer();
            }
        })
        .catch(error => {
            form_login.querySelector('.login-error').style.display = 'none';

            // console.log(error);
            if (error.response && error.response.message === "too_many_attempts") {
                form_login.querySelector('#error-login-many-attempts').style.display = 'block';
            } else if (error.response && (error.response.message === "auth_failed" || error.response.message === "invalid_credential")) {
                form_login.querySelector('#error-login-auth').style.display = 'block';
            } else {
                form_login.querySelector('#error-login-oops').style.display = 'block';
            }

            form_login.classList.remove('pending');

            if (swiperContainer_login) {
                updateSwiperContainer();
            }
        });

});

if(form_register){
    form_register.addEventListener('submit', function (e) {
        e.preventDefault();

        form_register.classList.add('pending');

        swiperContainer_register = form_register.closest('.swiper-container');

        if (swiperContainer_register && swiperContainer_register) {
            swiper_register = swiperContainer_register.swiper;
        } else {
            swiper_register = false;
        }

        var formData = new FormData(this);
        formData.append('terms', true);

        fetch('/register_user', {
            method: 'POST',
            headers: {
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
            },
            body: formData
        })
            .then(response => response.json())
            .then(data => {
                console.log(data);
                if (data['status'] == 'success') {
                    window.location.reload();
                } else if (data['status'] == 'error' && data.message === "email_taken") {
                    form_register.querySelector('#error-register-auth').style.display = 'block';
                    form_register.querySelector('#error-register-oops').style.display = 'none';
                } else {
                    form_register.querySelector('#error-register-oops').style.display = 'block';
                    form_register.querySelector('#error-register-auth').style.display = 'none';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                if (error.responseJSON.message === "email_taken") {
                    form_register.querySelector('#error-register-auth').style.display = 'block';
                    form_register.querySelector('#error-register-oops').style.display = 'none';
                } else {
                    form_register.querySelector('#error-register-oops').style.display = 'block';
                    form_register.querySelector('#error-register-auth').style.display = 'none';
                }
            })
            .finally(() => {
                form_register.classList.remove('pending');

                if (swiperContainer_register) {
                    updateSwiperContainer_register();
                }
            });
    });

}

